{
  "name": "react-vizly",
  "version": "1.0.31",
  "type": "module",
  "description": "Custom React chart library using ApexCharts",
  "main": "./dist/react-vizly.umd.cjs",
  "module": "./dist/react-vizly.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/react-vizly.js",
      "require": "./dist/react-vizly.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "apexcharts": "^4.0.0",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^4.5.0",
    "vite-plugin-dts": "^3.9.1"
  }
}
